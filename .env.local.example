# Tavily API Key (required for car search)
TAVILY_API_KEY=your_tavily_api_key_here

# OpenAI API Key (optional — fallback scoring works without it)
OPENAI_API_KEY=your_openai_api_key_here

# AWS Configuration (for DynamoDB caching — not yet implemented)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
DYNAMODB_TABLE_NAME=carma-listings
